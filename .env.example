# Origen canónico del sitio (metadata, Open Graph, URLs absolutas).
# En Vercel: Settings → Environment Variables → NEXT_PUBLIC_SITE_URL = https://lautor.dev (sin barra final).
# Local: copiá este archivo a .env.local si querés probar con el mismo dominio en dev.
NEXT_PUBLIC_SITE_URL=https://lautor.dev
